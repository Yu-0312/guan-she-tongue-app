# ────────────────────────────────────────────────────────────────
#  觀舌 Guān Shé · 環境變數設定
#  複製此檔案為 .env.local，並填入你的 Supabase 專案資訊
#  （.env.local 已加入 .gitignore，不會被提交）
# ────────────────────────────────────────────────────────────────

# Supabase 專案 URL（在 Supabase Dashboard → Settings → API 找到）
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Public Key（公開金鑰，可安全暴露在前端）
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# CNN 舌象分析 API（選填，預設使用本地 /api/cnn/tongue）
# VITE_CNN_API_URL=https://your-api.example.com/cnn/tongue

# 路由基礎路徑（部署在子目錄時設定，例如 /app）
# VITE_ROUTER_BASEPATH=
